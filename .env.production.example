# Production Environment Variables Example
# Set these in Vercel (Frontend) and Render (Backend) Dashboard

# FRONTEND (Vercel)
# Use the full URL of your Render backend
NEXT_PUBLIC_API_URL=https://your-backend-app.onrender.com/api

# BACKEND (Render)
# Database (Render can provide a PostgreSQL URL, or use a persistent disk for SQLite)
DATABASE_URL=sqlite:////var/lib/data/neuro_chat.db

# LLM Service
# In production, you might use an API key for OpenAI/Anthropic 
# instead of local Ollama, unless you host Ollama on a GPU instance.
OLLAMA_BASE_URL=http://localhost:11434 
